generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum VehicleType {
  VAN
  TRUCK
  PICKUP
  TRAILER
  BUS
}

enum ExpenseType {
  FUEL
  MAINTENANCE
  TOLL
  OTHER
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(DISPATCHER)
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  profileImage  String?
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model Vehicle {
  id                String          @id @default(cuid())
  registrationNo    String          @unique
  name              String
  model             String?
  type              VehicleType
  maxLoadCapacity   Float
  odometer          Float
  acquisitionCost   Float
  status            VehicleStatus   @default(AVAILABLE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  trips             Trip[]
  maintenance       Maintenance[]
  fuelLogs          FuelLog[]
  expenses          Expense[]
}

model Driver {
  id                String          @id @default(cuid())
  name              String
  licenseNumber     String          @unique
  licenseCategory   String
  licenseExpiry     DateTime
  contactNumber     String
  safetyScore       Float           @default(100)
  status            DriverStatus    @default(AVAILABLE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  trips             Trip[]
}

model Trip {
  id                String          @id @default(cuid())
  source            String
  destination       String
  cargoWeight       Float
  plannedDistance   Float
  actualDistance    Float?
  fuelConsumed      Float?
  revenue           Float?
  status            TripStatus      @default(DRAFT)
  vehicleId         String
  driverId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  driver            Driver          @relation(fields: [driverId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  fuelLogs          FuelLog[]
}

model Maintenance {
  id                String          @id @default(cuid())
  vehicleId         String
  title             String
  description       String?
  cost              Float
  status            MaintenanceStatus @default(OPEN)
  openedAt          DateTime        @default(now())
  closedAt          DateTime?

  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model FuelLog {
  id                String          @id @default(cuid())
  vehicleId         String
  tripId            String?
  liters            Float
  cost              Float
  date              DateTime        @default(now())

  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  trip              Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model Expense {
  id                String          @id @default(cuid())
  vehicleId         String
  type              ExpenseType
  amount            Float
  description       String?
  date              DateTime        @default(now())

  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
}
